# Copy this file to .env inside Backend/ and fill the values before starting the server.

# MongoDB Atlas
MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority&appName=<appName>

# JWT and session secrets
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

# Google OAuth (required if you use Google Sign-In)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Cloudinary (used for uploads)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# RFID / Arduino bridge
# Set this to your local serial device when running the RFID bridge locally.
# Examples: /dev/cu.usbserial-A5069RR4 (macOS), /dev/ttyUSB0 or /dev/ttyACM0 (Linux), COM3 (Windows)
ARDUINO_PORT=/dev/cu.usbserial-A5069RR4
START_RFID_BRIDGE=true

# Any other environment variables referenced by the app
# e.g., STRIPE_SECRET_KEY, SMTP credentials, etc.
