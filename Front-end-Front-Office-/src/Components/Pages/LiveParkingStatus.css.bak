.live-parking-status-container {
    background-color: #2c2c3e;
    padding: 20px;
    border-radius: 16px;
    margin-top: 20px;
    color: white;
}

.live-parking-status-container h3 {
    margin-bottom: 20px;
    text-align: center;
    font-size: 1.5rem;
}

.slots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 15px;
}

.slot-card {
    padding: 15px;
    border-radius: 8px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
}

.slot-card.available {
    background-color: #4CAF50; /* Green */
    border: 1px solid #388E3C;
}

.slot-card.occupied {
    background-color: #F44336; /* Red */
    border: 1px solid #D32F2F;
}

.slot-number {
    font-weight: bold;
    font-size: 1.1rem;
    margin-bottom: 5px;
}

.slot-status {
    font-size: 0.9rem;
}

.error-message {
    color: #ffcc00;
    text-align: center;
}
